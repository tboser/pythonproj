[project]
name = "{{ package_name }}"
{%- if variant == "library" %}
dynamic = ["version"]
{%- else %}
version = "0.1.0"
{%- endif %}
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
{%- if license == "MIT" %}
license = { text = "MIT" }
{%- elif license == "Apache-2.0" %}
license = { text = "Apache-2.0" }
{%- endif %}
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]
classifiers = [
    "Programming Language :: Python",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: {{ python_version }}",
{%- if license == "MIT" %}
    "License :: OSI Approved :: MIT License",
{%- elif license == "Apache-2.0" %}
    "License :: OSI Approved :: Apache Software License",
{%- endif %}
{%- if variant == "library" %}
    "Typing :: Typed",
{%- endif %}
]
dependencies = [
{%- if variant == "app" %}
    "pydantic-settings>=2.6.0",
{%- endif %}
{%- if variant == "cli" %}
    "cyclopts>=3.0.0",
{%- endif %}
]

{% if variant == "cli" -%}
[project.scripts]
{{ package_name }} = "{{ package_name }}.cli:launch"

{% endif -%}

{% if variant == "library" and open_source -%}
[project.urls]
Homepage = "https://github.com/{{ github_username }}/{{ package_name }}"
Repository = "https://github.com/{{ github_username }}/{{ package_name }}"
Documentation = "https://{{ package_name }}.readthedocs.io"
Issues = "https://github.com/{{ github_username }}/{{ package_name }}/issues"

{% endif -%}

[build-system]
{%- if variant == "library" %}
requires = ["hatchling", "uv-dynamic-versioning>=0.7.0"]
{%- else %}
requires = ["hatchling"]
{%- endif %}
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

{% if variant == "library" -%}
[tool.hatch.version]
source = "uv-dynamic-versioning"

[tool.uv-dynamic-versioning]
vcs = "git"
style = "pep440"

{% endif -%}

# ---------- Ruff -----------------------------------------------------------
[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = [
    "E",   # pycodestyle errors
    "W",   # pycodestyle warnings
    "F",   # pyflakes
    "I",   # isort
    "B",   # flake8-bugbear
    "C4",  # flake8-comprehensions
    "UP",  # pyupgrade
    "SIM", # flake8-simplify
]
ignore = [
    "E501",  # line length handled by formatter
    "B008",  # function call in default arg (needed for typer/cyclopts)
]

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

[tool.ruff.format]
quote-style = "double"

# ---------- ty (type checker) ---------------------------------------------
[tool.ty.environment]
python-version = "{{ python_version }}"
python = ".venv"

[tool.ty.rules]
redundant-cast = "ignore"

# ---------- Pytest ---------------------------------------------------------
[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
addopts = ["--strict-markers", "--strict-config", "-ra"]
xfail_strict = true
filterwarnings = ["error"]

[tool.coverage.run]
source = ["src/{{ package_name }}"]
branch = true

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "raise NotImplementedError",
    "if TYPE_CHECKING:",
    "@overload",
    "@deprecated",
]

# ---------- Dev dependencies ----------------------------------------------
[dependency-groups]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=1.0.0",
    "pytest-pretty>=1.3.0",
    "pytest-cov>=7.0.0",
    "inline-snapshot>=0.31.0",
    "dirty-equals>=0.11.0",
    "pytest-recording>=0.13.0",
    "ruff>=0.8.0",
    "ty>=0.0.9",
    "pre-commit>=4.0.0",
{%- if variant == "library" %}
    "mkdocs>=1.6.0",
    "mkdocs-material>=9.5.0",
    "mkdocs-llmstxt>=0.2.0",
    "mkdocstrings[python]>=0.27.0",
{%- endif %}
]
